# Copy to apps/web/.env.local — see SETUP.md for full documentation

# PostgreSQL (Docker local: port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/auxano?schema=public"

# Optional: Finnhub quotes (Yahoo used when unset) — https://finnhub.io
FINNHUB_API_KEY=

# Clerk auth — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
# Optional: Clerk Dashboard → Webhooks → user.created
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Local dev only — MUST be false in production
ALLOW_DEV_AUTH=true
NEXT_PUBLIC_ALLOW_DEV_AUTH=true
DEV_AUTH_SECRET=change-me-to-a-long-random-string

# Firebase (optional — not wired in code yet; see SETUP.md)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_USE_DEV_AUTH": "true",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "image": "latest",
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://auxano-red.vercel.app",
        "EXPO_PUBLIC_USE_DEV_AUTH": "false"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://auxano-red.vercel.app",
        "EXPO_PUBLIC_USE_DEV_AUTH": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "D49RVY375B",
        "ascAppId": "6776782489"
      }
    }
  }
}

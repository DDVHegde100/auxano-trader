# Copy to .env — or run `npm run start` to auto-generate

# Test login without Clerk (recommended for local dev)
EXPO_PUBLIC_USE_DEV_AUTH=true

# Your Mac's LAN IP + port 3000 (NOT localhost on a real iPhone)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Only needed if USE_DEV_AUTH=false
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

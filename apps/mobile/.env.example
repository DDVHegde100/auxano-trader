# Copy to apps/mobile/.env — see SETUP.md

# Mac LAN IP for physical device (not localhost)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Local dev login without Clerk
EXPO_PUBLIC_USE_DEV_AUTH=true

# Production: set false and use Clerk
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Firebase (optional — see SETUP.md)
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=

{
  "name": "auxano",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bash scripts/run-dev.sh",
    "run": "bash scripts/run-dev.sh",
    "expo": "cd apps/mobile && npx expo start --clear --lan",
    "fix:db": "bash scripts/fix-database.sh",
    "test:db": "node scripts/test-db.mjs",
    "test:auth": "node scripts/test-auth-local.mjs",
    "screenshots": "node scripts/capture-app-store-screenshots.mjs",
    "screenshots:6.5": "node scripts/capture-app-store-screenshots.mjs http://127.0.0.1:3000 --6.5",
    "screenshots:6.7": "node scripts/capture-app-store-screenshots.mjs http://127.0.0.1:3000 --6.7",
    "verify:production-ready": "node scripts/verify-production-ready.mjs",
    "fix:web": "rm -rf apps/web/.next",
    "dev": "npm run dev --workspace=@auxano/web",
    "dev:web": "npm run dev --workspace=@auxano/web",
    "dev:mobile": "npm run start --workspace=@auxano/mobile",
    "build": "npm run build --workspace=@auxano/web",
    "db:generate": "npm run generate --workspace=@auxano/database",
    "db:push": "npm run push --workspace=@auxano/database",
    "db:seed": "npm run seed --workspace=@auxano/database",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed && node scripts/test-db.mjs",
    "db:setup:supabase": "node scripts/setup-supabase.mjs",
    "check:prod-env": "CI=true NODE_ENV=production node scripts/check-prod-env.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "mobile:eas:init": "npm run eas:init --workspace=@auxano/mobile",
    "mobile:build:ios": "npm run build:ios --workspace=@auxano/mobile",
    "mobile:build:ios:preview": "npm run build:ios:preview --workspace=@auxano/mobile",
    "mobile:submit:ios": "npm run submit:ios --workspace=@auxano/mobile",
    "web:clean": "npm run dev:clean --workspace=@auxano/web",
    "lint": "npm run lint --workspaces --if-present",
    "git:bootstrap": "bash scripts/bootstrap-git-history.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
